{
  "name": "csharppainkiller",
  "displayName": "C# Painkiller",
  "publisher": "DzmitryPratsko",
  "description": "Smart file creation, code generation, project creation, namespace management and more for C#",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "C#",
    "CSharp",
    ".NET",
    "DOTNET",
    "dev kit",
    "CSharp Painkiller",
    "ASP.NET",
    "MediatR",
    "MitMediator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dzmprt/CSharpPainkiller"
  },
  "homepage": "https://github.com/dzmprt/CSharpPainkiller/blob/main/README.md",
  "icon": "images/CSharpPainkillerLogo.png",
  "activationEvents": [
    "onLanguage:csharp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "csharppainkiller.generateHandlerForFile",
        "title": "Generate Handler"
      },
      {
        "command": "csharppainkiller.goToHandlerForFile",
