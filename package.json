      },
      {
        "command": "csharppainkiller.createClass",
        "title": "Class"
      },
      {
        "command": "csharppainkiller.createRecord",
        "title": "Record"
      },
      {
        "command": "csharppainkiller.createStruct",
        "title": "Struct"
      },
      {
        "command": "csharppainkiller.createEnum",
        "title": "Enum"
      },
      {
        "command": "csharppainkiller.createInterface",
        "title": "Interface"
      },
      {
        "command": "csharppainkiller.createRecordStruct",
        "title": "Record Struct"
      },
      {
        "command": "csharppainkiller.adjustNamespace",
        "title": "Adjust Namespaces"
      },
      {
        "command": "csharppainkiller.renameFileByType",
        "title": "Rename File By Type"
      },
      {
        "command": "csharppainkiller.sortUsings",
        "title": "Sort Usings"
      },
      {
        "command": "csharppainkiller.extractInterface",
        "title": "Extract Interface"
      },
      {
        "command": "csharppainkiller.generateMapTo",
        "title": "Generate MapTo Method"
      },
      {
        "command": "csharppainkiller.generateMapFrom",
        "title": "Generate MapFrom Method"
      },
      {
        "command": "csharppainkiller.generateDto",
        "title": "Generate DTO with MapFrom"
      },
      {
        "command": "csharppainkiller.generateFluentValidator",
        "title": "Generate FluentValidation Validator"
      },
      {
        "command": "csharppainkiller.extractTypeToFile",
        "title": "Extract Type to File"
      },
      {
        "command": "csharppainkiller.templates.aspnet.emptyController",
        "title": "Empty Controller"
      },
      {
        "command": "csharppainkiller.templates.aspnet.efCrudController",
        "title": "EF CRUD Controller"
      },
      {
        "command": "csharppainkiller.templates.aspnet.emptyMinimalApi",
        "title": "Empty Minimal API"
      },
      {
        "command": "csharppainkiller.templates.aspnet.efCrudMinimalApi",
        "title": "EF CRUD Minimal API"
      },
      {
        "command": "csharppainkiller.efcore.createConfigurationFromFolder",
        "title": "EF Core Entity Configuration"
      },
      {
        "command": "csharppainkiller.efcore.createConfigurationFromFile",
        "title": "Generate EF Core Configuration"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createRequestAndHandler",
        "title": "Request and Handler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createRequest",
        "title": "Request"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createHandler",
        "title": "RequestHandler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createNotificationAndHandler",
        "title": "Notification and Handler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createNotification",
        "title": "Notification"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createNotificationHandler",
        "title": "NotificationHandler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createRequestAndHandler",
        "title": "Request and Handler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createRequest",
        "title": "Request"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createHandler",
        "title": "RequestHandler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createNotificationAndHandler",
        "title": "Notification and Handler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createNotification",
        "title": "Notification"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createNotificationHandler",
        "title": "NotificationHandler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createEmptyPipelineBehavior",
        "title": "Empty PipelineBehavior"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createFluentValidationBehavior",
        "title": "FluentValidation PipelineBehavior"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createEmptyPipelineBehavior",
        "title": "Empty PipelineBehavior"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createFluentValidationBehavior",
        "title": "FluentValidation PipelineBehavior"
      },
      {
        "command": "csharppainkiller.dotnet.createProject",
        "title": ".NET NEW"
      },
      {
        "command": "csharppainkiller.efcore.cmd.addMigration",
        "title": "Add Migration"
      },
      {
        "command": "csharppainkiller.efcore.cmd.updateDatabase",
        "title": "Update Database"
      },
      {
        "command": "csharppainkiller.efcore.cmd.listMigrations",
        "title": "List Migrations"
      },
      {
        "command": "csharppainkiller.efcore.cmd.scriptMigration",
        "title": "Script Migration"
      },
      {
        "command": "csharppainkiller.efcore.cmd.removeMigration",
        "title": "Remove Migration"
      }
    ],
    "submenus": [
      {
        "id": "csharppainkiller.create",
        "label": "C# Create"
      },
      {
        "id": "csharppainkiller.refactor",
        "label": "C# Refactor"
      },
      {
        "id": "csharppainkiller.templates",
        "label": "C# Generator"
      },
      {
        "id": "csharppainkiller.templates.aspnet",
        "label": "ASP.NET"
      },
      {
        "id": "csharppainkiller.templates.mediatr",
        "label": "MediatR"
      },
      {
        "id": "csharppainkiller.templates.mitmediator",
        "label": "MitMediator"
      },
      {
        "id": "csharppainkiller.templates.mediatr.pipeline",
        "label": "Generate PipelineBehavior"
      },
      {
        "id": "csharppainkiller.templates.mitmediator.pipeline",
        "label": "Generate PipelineBehavior"
      },
      {
        "id": "csharppainkiller.efcore",
        "label": "EF Core"
      },
      {
        "id": "csharppainkiller.efcoreCmd",
        "label": "Entity Framework CMD"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "submenu": "csharppainkiller.create",
          "group": "2_csharp@1"
        },
        {
          "submenu": "csharppainkiller.refactor",
          "group": "2_csharp@1"
        },
        {
          "when": "explorerResourceIsFolder",
          "submenu": "csharppainkiller.templates",
          "group": "2_csharp@2"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs && csharppainkiller.isMediatorFile",
          "command": "csharppainkiller.goToHandlerForFile",
          "group": "2_csharp@3"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs && csharppainkiller.isMediatorFile",
          "command": "csharppainkiller.generateHandlerForFile",
          "group": "2_csharp@4"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs",
          "command": "csharppainkiller.efcore.createConfigurationFromFile",
          "group": "2_csharp@5"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs",
          "command": "csharppainkiller.generateDto",
          "group": "2_csharp@6"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs",
          "command": "csharppainkiller.generateFluentValidator",
          "group": "2_csharp@7"
        },
        {
          "command": "csharppainkiller.dotnet.createProject",
          "when": "explorerResourceIsFolder",
          "group": "2_csharp@8"
        },
        {
          "when": "resourceExtname == .csproj",
          "submenu": "csharppainkiller.efcoreCmd",
          "group": "2_csharp@9"
        }
      ],
      "csharppainkiller.create": [
        {
          "command": "csharppainkiller.createClass",
          "group": "1_types@1"
        },
        {
          "command": "csharppainkiller.createRecord",
          "group": "1_types@2"
        },
        {
          "command": "csharppainkiller.createStruct",
          "group": "1_types@3"
        },
        {
          "command": "csharppainkiller.createEnum",
          "group": "1_types@4"
        },
        {
          "command": "csharppainkiller.createInterface",
          "group": "1_types@5"
        },
        {
          "command": "csharppainkiller.createRecordStruct",
          "group": "1_types@6"
        }
      ],
      "csharppainkiller.refactor": [
        {
          "command": "csharppainkiller.adjustNamespace",
          "group": "1_refactor@1"
        },
        {
          "command": "csharppainkiller.renameFileByType",
          "group": "1_refactor@2"
        },
        {
          "command": "csharppainkiller.sortUsings",
          "group": "1_refactor@3"
        },
        {
          "command": "csharppainkiller.extractInterface",
          "when": "!explorerResourceIsFolder && resourceExtname == .cs",
          "group": "1_refactor@4"
        }
      ],
      "csharppainkiller.templates": [
        {
          "submenu": "csharppainkiller.templates.aspnet",
          "group": "1_templates@1"
        },
        {
          "submenu": "csharppainkiller.templates.mediatr",
          "group": "1_templates@2"
        },
        {
          "submenu": "csharppainkiller.templates.mitmediator",
          "group": "1_templates@3"
        },
        {
          "submenu": "csharppainkiller.efcore",
          "group": "1_templates@4"
        }
      ],
      "csharppainkiller.templates.aspnet": [
        {
          "command": "csharppainkiller.templates.aspnet.emptyController",
          "group": "1_aspnet@1"
        },
        {
          "command": "csharppainkiller.templates.aspnet.efCrudController",
          "group": "1_aspnet@2"
        },
        {
          "command": "csharppainkiller.templates.aspnet.emptyMinimalApi",
          "group": "1_aspnet@3"
        },
        {
          "command": "csharppainkiller.templates.aspnet.efCrudMinimalApi",
          "group": "1_aspnet@4"
        }
      ],
      "csharppainkiller.templates.mediatr": [
        {
          "command": "csharppainkiller.templates.mediatr.createRequestAndHandler",
          "group": "1_mediatr@1"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createRequest",
          "group": "1_mediatr@2"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createHandler",
          "group": "1_mediatr@3"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotificationAndHandler",
          "group": "2_mediatr@1"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotification",
          "group": "2_mediatr@2"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotificationHandler",
          "group": "2_mediatr@3"
        },
        {
          "submenu": "csharppainkiller.templates.mediatr.pipeline",
          "group": "3_mediatr@1"
        }
      ],
      "csharppainkiller.templates.mediatr.pipeline": [
        {
          "command": "csharppainkiller.templates.mediatr.createEmptyPipelineBehavior",
          "group": "1_pipeline@1"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createFluentValidationBehavior",
          "group": "1_pipeline@2"
        }
      ],
      "csharppainkiller.templates.mitmediator": [
        {
          "command": "csharppainkiller.templates.mitmediator.createRequestAndHandler",
          "group": "1_mitmediator@1"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createRequest",
          "group": "1_mitmediator@2"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createHandler",
          "group": "1_mitmediator@3"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createNotificationAndHandler",
          "group": "2_mitmediator@1"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createNotification",
          "group": "2_mitmediator@2"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createNotificationHandler",
          "group": "2_mitmediator@3"
        },
        {
          "submenu": "csharppainkiller.templates.mitmediator.pipeline",
          "group": "3_mitmediator@1"
        }
      ],
      "csharppainkiller.templates.mitmediator.pipeline": [
        {
          "command": "csharppainkiller.templates.mitmediator.createEmptyPipelineBehavior",
          "group": "1_pipeline@1"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createFluentValidationBehavior",
          "group": "1_pipeline@2"
        }
      ],
      "csharppainkiller.efcore": [
        {
          "command": "csharppainkiller.efcore.createConfigurationFromFolder",
          "group": "1_efcore@1"
        }
      ],
      "csharppainkiller.efcoreCmd": [
        {
          "command": "csharppainkiller.efcore.cmd.addMigration",
          "group": "1_efcmd@1"
        },
        {
          "command": "csharppainkiller.efcore.cmd.removeMigration",
          "group": "1_efcmd@2"
        },
        {
          "command": "csharppainkiller.efcore.cmd.listMigrations",
          "group": "1_efcmd@3"
        },
        {
          "command": "csharppainkiller.efcore.cmd.scriptMigration",
          "group": "1_efcmd@4"
        },
        {
          "command": "csharppainkiller.efcore.cmd.updateDatabase",
          "group": "1_efcmd@5"
        }
      ]
    },
    "configuration": []
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.92.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
