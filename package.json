{
  "name": "csharppainkiller",
  "displayName": "C# Painkiller",
  "publisher": "DzmitryPratsko",
  "description": "Smart file creation, code generation, project creation, namespace management and more for C#",
  "version": "0.0.7",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "C#",
    "CSharp",
    ".NET",
    "DOTNET",
    "dev kit",
    "CSharp Painkiller",
    "ASP.NET",
    "MediatR",
    "MitMediator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dzmprt/CSharpPainkiller"
  },
  "homepage": "https://github.com/dzmprt/CSharpPainkiller/blob/main/README.md",
  "icon": "images/logo.png",
  "activationEvents": [
    "onLanguage:csharp",
    "workspaceContains:**/*.csproj",
    "workspaceContains:**/*.sln",
    "workspaceContains:**/*.slnx"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "csharppainkiller.generateHandlerForFile",
        "title": "Generate Handler"
      },
      {
        "command": "csharppainkiller.goToHandlerForFile",
        "title": "Go To Handler"
      },
      {
        "command": "csharppainkiller.createClass",
        "title": "Class"
      },
      {
        "command": "csharppainkiller.createRecord",
        "title": "Record"
      },
      {
        "command": "csharppainkiller.createStruct",
        "title": "Struct"
      },
      {
        "command": "csharppainkiller.createEnum",
        "title": "Enum"
      },
      {
        "command": "csharppainkiller.createInterface",
        "title": "Interface"
      },
      {
        "command": "csharppainkiller.createRecordStruct",
        "title": "Record Struct"
      },
      {
        "command": "csharppainkiller.adjustNamespace",
        "title": "Adjust Namespaces"
      },
      {
        "command": "csharppainkiller.renameFileByType",
        "title": "Rename File By Type"
      },
      {
        "command": "csharppainkiller.sortUsings",
        "title": "Sort Usings"
      },
      {
        "command": "csharppainkiller.extractInterface",
        "title": "Extract Interface"
      },
      {
        "command": "csharppainkiller.generateMapTo",
        "title": "Generate MapTo Method"
      },
      {
        "command": "csharppainkiller.generateMapFrom",
        "title": "Generate MapFrom Method"
      },
      {
        "command": "csharppainkiller.generateDto",
        "title": "Generate DTO with MapFrom"
      },
      {
        "command": "csharppainkiller.generateFluentValidator",
        "title": "Generate FluentValidation Validator"
      },
      {
        "command": "csharppainkiller.extractTypeToFile",
        "title": "Extract Type to File"
      },
      {
        "command": "csharppainkiller.templates.aspnet.emptyController",
        "title": "Empty Controller"
      },
      {
        "command": "csharppainkiller.templates.aspnet.efCrudController",
        "title": "EF CRUD Controller"
      },
      {
        "command": "csharppainkiller.templates.aspnet.emptyMinimalApi",
        "title": "Empty Minimal API"
      },
      {
        "command": "csharppainkiller.templates.aspnet.efCrudMinimalApi",
        "title": "EF CRUD Minimal API"
      },
      {
        "command": "csharppainkiller.efcore.createConfigurationFromFolder",
        "title": "EF Core Entity Configuration"
      },
      {
        "command": "csharppainkiller.efcore.createConfigurationFromFile",
        "title": "Generate EF Core Configuration"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createRequestAndHandler",
        "title": "Request and Handler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createRequest",
        "title": "Request"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createHandler",
        "title": "RequestHandler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createNotificationAndHandler",
        "title": "Notification and Handler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createNotification",
        "title": "Notification"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createNotificationHandler",
        "title": "NotificationHandler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createRequestAndHandler",
        "title": "Request and Handler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createRequest",
        "title": "Request"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createHandler",
        "title": "RequestHandler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createNotificationAndHandler",
        "title": "Notification and Handler"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createNotification",
        "title": "Notification"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createNotificationHandler",
        "title": "NotificationHandler"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createEmptyPipelineBehavior",
        "title": "Empty PipelineBehavior"
      },
      {
        "command": "csharppainkiller.templates.mediatr.createFluentValidationBehavior",
        "title": "FluentValidation PipelineBehavior"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createEmptyPipelineBehavior",
        "title": "Empty PipelineBehavior"
      },
      {
        "command": "csharppainkiller.templates.mitmediator.createFluentValidationBehavior",
        "title": "FluentValidation PipelineBehavior"
      },
      {
        "command": "csharppainkiller.dotnet.createProject",
        "title": ".NET NEW"
      },
      {
        "command": "csharppainkiller.projects.createProject",
        "title": "Create .NET Project",
        "icon": "$(new-folder)"
      },
      {
        "command": "csharppainkiller.projects.createFolder",
        "title": "Create Folder",
        "icon": "$(folder)"
      },
      {
        "command": "csharppainkiller.projects.deleteFolder",
        "title": "Delete Folder",
        "icon": "$(trash)"
      },
      {
        "command": "csharppainkiller.projects.excludeProject",
        "title": "Exclude Project",
        "icon": "$(remove)"
      },
      {
        "command": "csharppainkiller.projects.includeProject",
        "title": "Include Existing Project",
        "icon": "$(add)"
      },
      {
        "command": "csharppainkiller.projects.deleteProject",
        "title": "Delete Project",
        "icon": "$(trash)"
      },
      {
        "command": "csharppainkiller.projects.addProjectReference",
        "title": "Add Project Reference",
        "icon": "$(references)"
      },
      {
        "command": "csharppainkiller.projects.removeProjectReference",
        "title": "Remove Project Reference",
        "icon": "$(remove)"
      },
      {
        "command": "csharppainkiller.projects.addPackageReference",
        "title": "Add NuGet Package",
        "icon": "$(add)"
      },
      {
        "command": "csharppainkiller.projects.removePackageReference",
        "title": "Remove NuGet Package",
        "icon": "$(remove)"
      },
      {
        "command": "csharppainkiller.efcore.cmd.addMigration",
        "title": "Add Migration"
      },
      {
        "command": "csharppainkiller.efcore.cmd.updateDatabase",
        "title": "Update Database"
      },
      {
        "command": "csharppainkiller.efcore.cmd.listMigrations",
        "title": "List Migrations"
      },
      {
        "command": "csharppainkiller.efcore.cmd.scriptMigration",
        "title": "Script Migration"
      },
      {
        "command": "csharppainkiller.efcore.cmd.removeMigration",
        "title": "Remove Migration"
      }
    ],
    "submenus": [
      {
        "id": "csharppainkiller.create",
        "label": "C# Create"
      },
      {
        "id": "csharppainkiller.refactor",
        "label": "C# Refactor"
      },
      {
        "id": "csharppainkiller.templates",
        "label": "C# Generator"
      },
      {
        "id": "csharppainkiller.templates.aspnet",
        "label": "ASP.NET"
      },
      {
        "id": "csharppainkiller.templates.mediatr",
        "label": "MediatR"
      },
      {
        "id": "csharppainkiller.templates.mitmediator",
        "label": "MitMediator"
      },
      {
        "id": "csharppainkiller.templates.mediatr.pipeline",
        "label": "Generate PipelineBehavior"
      },
      {
        "id": "csharppainkiller.templates.mitmediator.pipeline",
        "label": "Generate PipelineBehavior"
      },
      {
        "id": "csharppainkiller.efcore",
        "label": "EF Core"
      },
      {
        "id": "csharppainkiller.efcoreCmd",
        "label": "Entity Framework CMD"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "csharppainkiller.projects",
          "name": "Solution Structure (beta)",
          "when": "workspaceFolderCount != 0 && csharppainkiller.hasSolution && config.csharppainkiller.solutionStructure.show"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "csharppainkiller.generateHandlerForFile",
          "when": "config.csharppainkiller.templates.showMediatR || config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.generateFluentValidator",
          "when": "config.csharppainkiller.templates.showFluentValidation"
        },
        {
          "command": "csharppainkiller.templates.aspnet.emptyController",
          "when": "config.csharppainkiller.templates.showAspNet"
        },
        {
          "command": "csharppainkiller.templates.aspnet.efCrudController",
          "when": "config.csharppainkiller.templates.showAspNet"
        },
        {
          "command": "csharppainkiller.templates.aspnet.emptyMinimalApi",
          "when": "config.csharppainkiller.templates.showAspNet"
        },
        {
          "command": "csharppainkiller.templates.aspnet.efCrudMinimalApi",
          "when": "config.csharppainkiller.templates.showAspNet"
        },
        {
          "command": "csharppainkiller.efcore.createConfigurationFromFolder",
          "when": "config.csharppainkiller.templates.showEfCore"
        },
        {
          "command": "csharppainkiller.efcore.createConfigurationFromFile",
          "when": "config.csharppainkiller.templates.showEfCore"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createRequestAndHandler",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createRequest",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createHandler",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotificationAndHandler",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotification",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotificationHandler",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createEmptyPipelineBehavior",
          "when": "config.csharppainkiller.templates.showMediatR"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createFluentValidationBehavior",
          "when": "config.csharppainkiller.templates.showMediatR && config.csharppainkiller.templates.showFluentValidation"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createRequestAndHandler",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createRequest",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createHandler",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createNotificationAndHandler",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createNotification",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createNotificationHandler",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createEmptyPipelineBehavior",
          "when": "config.csharppainkiller.templates.showMitMediator"
        },
        {
          "command": "csharppainkiller.templates.mitmediator.createFluentValidationBehavior",
          "when": "config.csharppainkiller.templates.showMitMediator && config.csharppainkiller.templates.showFluentValidation"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "submenu": "csharppainkiller.create",
          "group": "2_csharp@1"
        },
        {
          "submenu": "csharppainkiller.refactor",
          "group": "2_csharp@1"
        },
        {
          "when": "explorerResourceIsFolder",
          "submenu": "csharppainkiller.templates",
          "group": "2_csharp@2"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs && csharppainkiller.isMediatorFile",
          "command": "csharppainkiller.goToHandlerForFile",
          "group": "2_csharp@3"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs && csharppainkiller.isMediatorFile && (config.csharppainkiller.templates.showMediatR || config.csharppainkiller.templates.showMitMediator)",
          "command": "csharppainkiller.generateHandlerForFile",
          "group": "2_csharp@4"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs && config.csharppainkiller.templates.showEfCore",
          "command": "csharppainkiller.efcore.createConfigurationFromFile",
          "group": "2_csharp@5"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs",
          "command": "csharppainkiller.generateDto",
          "group": "2_csharp@6"
        },
        {
          "when": "!explorerResourceIsFolder && resourceExtname == .cs && config.csharppainkiller.templates.showFluentValidation",
          "command": "csharppainkiller.generateFluentValidator",
          "group": "2_csharp@7"
        },
        {
          "command": "csharppainkiller.dotnet.createProject",
          "when": "explorerResourceIsFolder",
          "group": "2_csharp@8"
        },
        {
          "when": "resourceExtname == .csproj",
          "submenu": "csharppainkiller.efcoreCmd",
          "group": "2_csharp@9"
        }
      ],
      "editor/context": [
        {
          "when": "editorLangId == csharp && resourceExtname == .cs && csharppainkiller.isMediatorFile",
          "command": "csharppainkiller.goToHandlerForFile",
          "group": "navigation@10"
        },
        {
          "when": "editorLangId == csharp && resourceExtname == .cs",
          "command": "csharppainkiller.generateMapTo",
          "group": "2_csharp@1"
        },
        {
          "when": "editorLangId == csharp && resourceExtname == .cs",
          "command": "csharppainkiller.generateMapFrom",
          "group": "2_csharp@2"
        },
        {
          "when": "editorLangId == csharp && resourceExtname == .cs",
          "command": "csharppainkiller.generateDto",
          "group": "2_csharp@3"
        },
        {
          "when": "editorLangId == csharp && resourceExtname == .cs && config.csharppainkiller.templates.showFluentValidation",
          "command": "csharppainkiller.generateFluentValidator",
          "group": "2_csharp@4"
        }
      ],
      "view/title": [],
      "view/item/context": [
        {
          "command": "csharppainkiller.projects.createProject",
          "when": "view == csharppainkiller.projects && (viewItem == csharppainkiller.solution || viewItem == csharppainkiller.folder)",
          "group": "inline@1"
        },
        {
          "command": "csharppainkiller.projects.createFolder",
          "when": "view == csharppainkiller.projects && (viewItem == csharppainkiller.solution || viewItem == csharppainkiller.folder)",
          "group": "inline@2"
        },
        {
          "command": "csharppainkiller.projects.deleteFolder",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.folder",
          "group": "inline@3"
        },
        {
          "command": "csharppainkiller.projects.includeProject",
          "when": "view == csharppainkiller.projects && (viewItem == csharppainkiller.excludedProjects || viewItem == csharppainkiller.excludedProject)",
          "group": "inline@4"
        },
        {
          "command": "csharppainkiller.projects.includeProject",
          "when": "view == csharppainkiller.projects && (viewItem == csharppainkiller.solution || viewItem == csharppainkiller.folder)",
          "group": "navigation@4"
        },
        {
          "command": "csharppainkiller.projects.addProjectReference",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.referenceGroup",
          "group": "inline@1"
        },
        {
          "command": "csharppainkiller.projects.removeProjectReference",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.projectReference",
          "group": "inline@1"
        },
        {
          "command": "csharppainkiller.projects.addPackageReference",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.packageGroup",
          "group": "inline@1"
        },
        {
          "command": "csharppainkiller.projects.removePackageReference",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.packageReference",
          "group": "inline@1"
        },
        {
          "command": "csharppainkiller.projects.addPackageReference",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.project",
          "group": "navigation@5"
        },
        {
          "command": "csharppainkiller.projects.excludeProject",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.project",
          "group": "inline@2"
        },
        {
          "command": "csharppainkiller.projects.deleteProject",
          "when": "view == csharppainkiller.projects && viewItem == csharppainkiller.project",
          "group": "inline@3"
        }
      ],
      "csharppainkiller.create": [
        {
          "command": "csharppainkiller.createClass",
          "group": "1_types@1"
        },
        {
          "command": "csharppainkiller.createRecord",
          "group": "1_types@2"
        },
        {
          "command": "csharppainkiller.createStruct",
          "group": "1_types@3"
        },
        {
          "command": "csharppainkiller.createEnum",
          "group": "1_types@4"
        },
        {
          "command": "csharppainkiller.createInterface",
          "group": "1_types@5"
        },
        {
          "command": "csharppainkiller.createRecordStruct",
          "group": "1_types@6"
        }
      ],
      "csharppainkiller.refactor": [
        {
          "command": "csharppainkiller.adjustNamespace",
          "group": "1_refactor@1"
        },
        {
          "command": "csharppainkiller.renameFileByType",
          "group": "1_refactor@2"
        },
        {
          "command": "csharppainkiller.sortUsings",
          "group": "1_refactor@3"
        },
        {
          "command": "csharppainkiller.extractInterface",
          "when": "!explorerResourceIsFolder && resourceExtname == .cs",
          "group": "1_refactor@4"
        }
      ],
      "csharppainkiller.templates": [
        {
          "submenu": "csharppainkiller.templates.aspnet",
          "when": "config.csharppainkiller.templates.showAspNet",
          "group": "1_templates@1"
        },
        {
          "submenu": "csharppainkiller.templates.mediatr",
          "when": "config.csharppainkiller.templates.showMediatR",
          "group": "1_templates@2"
        },
        {
          "submenu": "csharppainkiller.templates.mitmediator",
          "when": "config.csharppainkiller.templates.showMitMediator",
          "group": "1_templates@3"
        },
        {
          "submenu": "csharppainkiller.efcore",
          "when": "config.csharppainkiller.templates.showEfCore",
          "group": "1_templates@4"
        }
      ],
      "csharppainkiller.templates.aspnet": [
        {
          "command": "csharppainkiller.templates.aspnet.emptyController",
          "group": "1_aspnet@1"
        },
        {
          "command": "csharppainkiller.templates.aspnet.efCrudController",
          "group": "1_aspnet@2"
        },
        {
          "command": "csharppainkiller.templates.aspnet.emptyMinimalApi",
          "group": "1_aspnet@3"
        },
        {
          "command": "csharppainkiller.templates.aspnet.efCrudMinimalApi",
          "group": "1_aspnet@4"
        }
      ],
      "csharppainkiller.templates.mediatr": [
        {
          "command": "csharppainkiller.templates.mediatr.createRequestAndHandler",
          "group": "1_mediatr@1"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createRequest",
          "group": "1_mediatr@2"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createHandler",
          "group": "1_mediatr@3"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotificationAndHandler",
          "group": "2_mediatr@1"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotification",
          "group": "2_mediatr@2"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createNotificationHandler",
          "group": "2_mediatr@3"
        },
        {
          "submenu": "csharppainkiller.templates.mediatr.pipeline",
          "group": "3_mediatr@1"
        }
      ],
