        {
          "command": "csharppainkiller.templates.mediatr.createEmptyPipelineBehavior",
          "group": "1_pipeline@1"
        },
        {
          "command": "csharppainkiller.templates.mediatr.createFluentValidationBehavior",
          "when": "config.csharppainkiller.templates.showFluentValidation",
          "group": "1_pipeline@2"
        }
      ],
      "csharppainkiller.templates.mitmediator": [
        {
          "command": "csharppainkiller.templates.mitmediator.createRequestAndHandler",
